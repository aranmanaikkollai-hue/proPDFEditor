<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/toolbar_container"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_annotation_toolbar"
    android:padding="8dp"
    android:elevation="8dp">

    <ImageButton
        android:id="@+id/btn_select"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_tool_button_normal"
        android:src="@drawable/ic_select"
        android:contentDescription="Select"
        android:padding="8dp"
        android:scaleType="fitCenter" />

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#FFE0E0E0"
        android:layout_marginHorizontal="4dp" />

    <ImageButton
        android:id="@+id/btn_highlight"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_tool_button_normal"
        android:src="@drawable/ic_highlight"
        android:contentDescription="Highlight"
        android:padding="8dp" />

    <ImageButton
        android:id="@+id/btn_underline"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_tool_button_normal"
        android:src="@drawable/ic_underline"
        android:contentDescription="Underline"
        android:padding="8dp" />

    <ImageButton
        android:id="@+id/btn_strikeout"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_tool_button_normal"
        android:src="@drawable/ic_strikeout"
        android:contentDescription="Strikeout"
        android:padding="8dp" />

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#FFE0E0E0"
        android:layout_marginHorizontal="4dp" />

    <ImageButton
        android:id="@+id/btn_pencil"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_tool_button_normal"
        android:src="@drawable/ic_pencil"
        android:contentDescription="Pencil"
        android:padding="8dp" />

    <ImageButton
        android:id="@+id/btn_freehand"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_tool_button_normal"
        android:src="@drawable/ic_brush"
        android:contentDescription="Freehand"
        android:padding="8dp" />

    <ImageButton
        android:id="@+id/btn_eraser"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_tool_button_normal"
        android:src="@drawable/ic_eraser"
        android:contentDescription="Eraser"
        android:padding="8dp" />

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#FFE0E0E0"
        android:layout_marginHorizontal="4dp" />

    <ImageButton
        android:id="@+id/btn_arrow"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_tool_button_normal"
        android:src="@drawable/ic_arrow"
        android:contentDescription="Arrow"
        android:padding="8dp" />

    <ImageButton
        android:id="@+id/btn_rectangle"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_tool_button_normal"
        android:src="@drawable/ic_rectangle"
        android:contentDescription="Rectangle"
        android:padding="8dp" />

    <ImageButton
        android:id="@+id/btn_circle"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_tool_button_normal"
        android:src="@drawable/ic_circle"
        android:contentDescription="Circle"
        android:padding="8dp" />

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#FFE0E0E0"
        android:layout_marginHorizontal="4dp" />

    <ImageButton
        android:id="@+id/btn_text"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_tool_button_normal"
        android:src="@drawable/ic_text_comment"
        android:contentDescription="Text Comment"
        android:padding="8dp" />

    <ImageButton
        android:id="@+id/btn_sticky"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_tool_button_normal"
        android:src="@drawable/ic_sticky_note"
        android:contentDescription="Sticky Note"
        android:padding="8dp" />

    <ImageButton
        android:id="@+id/btn_signature"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_tool_button_normal"
        android:src="@drawable/ic_signature"
        android:contentDescription="Signature"
        android:padding="8dp" />

    <ImageButton
        android:id="@+id/btn_image_stamp"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_tool_button_normal"
        android:src="@drawable/ic_image"
        android:contentDescription="Image Stamp"
        android:padding="8dp" />

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#FFE0E0E0"
        android:layout_marginHorizontal="4dp" />

    <ImageButton
        android:id="@+id/btn_color"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_tool_button_normal"
        android:contentDescription="Color"
        android:padding="8dp" />

    <View
        android:id="@+id/color_indicator"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="center_vertical"
        android:background="@drawable/bg_color_indicator"
        android:layout_marginHorizontal="4dp" />

    <ImageButton
        android:id="@+id/btn_stroke_width"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_tool_button_normal"
        android:src="@drawable/ic_stroke_width"
        android:contentDescription="Stroke Width"
        android:padding="8dp" />

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#FFE0E0E0"
        android:layout_marginHorizontal="4dp" />

    <ImageButton
        android:id="@+id/btn_undo"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_tool_button_normal"
        android:src="@drawable/ic_undo"
        android:contentDescription="Undo"
        android:padding="8dp" />

    <ImageButton
        android:id="@+id/btn_redo"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_tool_button_normal"
        android:src="@drawable/ic_redo"
        android:contentDescription="Redo"
        android:padding="8dp" />

    <ImageButton
        android:id="@+id/btn_clear"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_tool_button_normal"
        android:src="@drawable/ic_clear"
        android:contentDescription="Clear"
        android:padding="8dp" />

    <ImageButton
        android:id="@+id/btn_export"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_tool_button_normal"
        android:src="@drawable/ic_export"
        android:contentDescription="Export"
        android:padding="8dp" />

</LinearLayout>
