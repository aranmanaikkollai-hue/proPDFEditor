<?xml version="1.0" encoding="utf-8"?>
<paths>
    <!-- App internal files -->
    <files-path          name="internal"       path="."/>
    <!-- App cache -->
    <cache-path          name="cache"          path="."/>
    <!-- App external files (Android/data/...) -->
    <external-files-path name="app_external"   path="."/>
