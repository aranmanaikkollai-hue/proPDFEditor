    <external-cache-path name="ext_cache"      path="."/>
    <!-- Public Downloads — where tool output is saved -->
    <external-path       name="downloads"      path="Download/"/>
    <!-- Full external (fallback) -->
    <external-path       name="external"       path="."/>
</paths>
